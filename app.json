{
  "expo": {
    "name": "¿Cuánto cuesta?",
    "slug": "cuanto-cuesta-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cuantocuesta",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1B2838"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cuantocuesta.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B2838"
      },
      "package": "com.cuantocuesta.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
